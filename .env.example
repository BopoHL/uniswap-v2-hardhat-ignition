# Sepolia JSON-RPC endpoint from Alchemy, Infura, or another provider.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Test-only deployer key. Never use a key that controls real funds.
PRIVATE_KEY=0xYOUR_TEST_PRIVATE_KEY

# Optional Sepolia liquidity/trade sizes. Values use 18 decimals.
TOKEN_LIQUIDITY=10000
ETH_LIQUIDITY=0.01
FIRST_ETH_TRADE=0.0001
TOKEN_SELL_TRADE=20
SECOND_ETH_TRADE=0.00005

