{
  "name": "uniswap-v2-local-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Hardhat Ignition deployment of Uniswap V2 with a custom OpenZeppelin ERC-20 token",
  "scripts": {
    "compile": "hardhat compile",
    "demo": "hardhat run scripts/create-pool-and-trade.js",
    "deploy:localhost": "hardhat ignition deploy ignition/modules/UniswapV2Module.js --network localhost --reset",
    "pool:localhost": "hardhat run scripts/create-pool-and-trade.js --network localhost",
    "deploy:sepolia": "hardhat ignition deploy ignition/modules/UniswapV2Module.js --network sepolia",
    "pool:sepolia": "hardhat run scripts/create-pool-and-trade.js --network sepolia",
    "node": "hardhat node",
    "test": "hardhat run scripts/create-pool-and-trade.js",
    "verify:vendor": "node scripts/verify-vendored-source.js"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1",
    "@uniswap/v2-core": "1.0.1",
    "@uniswap/v2-periphery": "1.1.0-beta.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "4.0.14",
    "@nomicfoundation/hardhat-ignition-ethers": "3.1.6",
    "dotenv": "17.4.2",
    "ethers": "6.17.0",
    "hardhat": "3.9.1"
  },
  "engines": {
    "node": ">=22.10.0"
  }
}
